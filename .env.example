# SMTP Configuration
# Configure these to enable "Send via SMTP" functionality.
# Without these, you can still use "Copy to Clipboard" to get email-safe HTML.

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=your-username@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=Your Name <your-username@example.com>
